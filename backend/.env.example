AGENT_FORGE_ENV=development
AGENT_FORGE_DATABASE_URL=sqlite:///../data/agent-forge.db
AGENT_FORGE_RUNTIME_STATE_BACKEND=sqlite
AGENT_FORGE_RUNTIME_STATE_DIR=../data/runtime/langgraph
# 共享/生产环境改为 postgres；为空时复用 AGENT_FORGE_DATABASE_URL
AGENT_FORGE_RUNTIME_STATE_POSTGRES_URL=
AGENT_FORGE_SECRET_KEY=replace-with-a-long-random-secret
AGENT_FORGE_BOOTSTRAP_EMAIL=admin@example.com
AGENT_FORGE_BOOTSTRAP_PASSWORD=replace-with-a-strong-password
AGENT_FORGE_BOOTSTRAP_ORG_NAME=Agent Forge
AGENT_FORGE_CORS_ORIGINS=["http://localhost:5183","http://127.0.0.1:5183"]
AGENT_FORGE_EGRESS_ALLOWED_HOSTS=[]
AGENT_FORGE_EGRESS_BLOCKED_HOSTS=[]
AGENT_FORGE_EGRESS_ALLOW_PRIVATE_NETWORKS=false
AGENT_FORGE_EGRESS_ALLOW_LOCALHOST=false
